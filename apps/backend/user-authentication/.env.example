# Port d’écoute de l’API — le frontend utilise VITE_AUTH_API_URL avec la même valeur (ex. http://localhost:3000)
PORT=3000

# Origines autorisées pour CORS (navigateur). Par défaut le code inclut http://localhost:5173 (Vite).
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Compte super admin recréé / resynchronisé au démarrage (approuvé + actif)
# SUPER_ADMIN_SEED=false pour désactiver
SUPER_ADMIN_CIN=00000001
SUPER_ADMIN_PASSWORD=Admin@2024!
SUPER_ADMIN_EMAIL=superadmin@smartsite.local
# SUPER_ADMIN_FORCE_PASSWORD=true  # réapplique le hash du mot de passe à chaque démarrage (dev uniquement)
